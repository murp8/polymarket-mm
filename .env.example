# ─── Polymarket Credentials ───────────────────────────────────────────────────
# Your Polygon wallet private key (with leading 0x)
POLYMARKET_PRIVATE_KEY=0xYOUR_PRIVATE_KEY_HERE

# Wallet address (checksummed)
POLYMARKET_WALLET_ADDRESS=0xYOUR_WALLET_ADDRESS_HERE

# For proxy wallets (Magic/email), set POLYMARKET_FUNDER_ADDRESS to the
# address that actually holds funds. Leave blank for EOA (MetaMask / hw wallet).
POLYMARKET_FUNDER_ADDRESS=

# Signature type: 0=EOA, 1=Magic/email, 2=browser proxy wallet
POLYMARKET_SIGNATURE_TYPE=0

# ─── The Odds API ─────────────────────────────────────────────────────────────
# Get a free key at https://the-odds-api.com/ (500 req/month free)
# Paid plans start at $30/month for 20K requests
ODDS_API_KEY=YOUR_ODDS_API_KEY_HERE

# ─── Optional Overrides ───────────────────────────────────────────────────────
# Override config.yaml values via env vars using POLYMARKET_MM__ prefix:
# POLYMARKET_MM__QUOTING__BASE_ORDER_SIZE=100
# POLYMARKET_MM__RISK__MAX_TOTAL_USDC_IN_ORDERS=2000
# POLYMARKET_MM__LOGGING__LEVEL=DEBUG
